@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="topbar">
    <nav class="navbar">
        <NavLink href="/" Match="NavLinkMatch.All"> Series y Películas</NavLink>
        <NavLink href="/libros">Libros, Manga y Cómics</NavLink>
    </nav>
    <button class="theme-toggle" @onclick="ToggleTheme">
        @(esOscuro ? "☀️" : "🌙")
    </button>
</div>

<div class="page">
    <main>@Body</main>
</div>

@code {
    private bool esOscuro = true;

    protected override async Task OnInitializedAsync()
    {
        var actual = await JS.InvokeAsync<string>("themeInterop.get");
        esOscuro = actual != "light";
    }

    private async Task ToggleTheme()
    {
        esOscuro = !esOscuro;
        await JS.InvokeVoidAsync("themeInterop.set", esOscuro ? "dark" : "light");
    }
}
