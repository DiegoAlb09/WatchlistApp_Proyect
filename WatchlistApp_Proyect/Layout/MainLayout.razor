@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject AuthService Auth
@inject NavigationManager Nav

<div class="topbar">
  <nav class="navbar">
    <NavLink href="/" Match="NavLinkMatch.All">
      <Icon Name="film" /><span>Series y Películas</span>
    </NavLink>
    <NavLink href="/libros">
      <Icon Name="book" /><span>Libros, Manga y Cómics</span>
    </NavLink>
    <NavLink href="/estadisticas">
      <Icon Name="chart" /><span>Estadísticas</span>
    </NavLink>
  </nav>
  <div class="topbar-right">
    <AuthorizeView>
      <Authorized>
        <span class="usuario-email">@context.User.FindFirst("email")?.Value</span>
        <button class="btn-random" @onclick="CerrarSesion">Salir</button>
      </Authorized>
    </AuthorizeView>
    <button class="theme-toggle" title="Cambiar tema" @onclick="ToggleTheme">
      <Icon Name="@(esOscuro ? "sun" : "moon")" />
    </button>
  </div>
</div>

<div class="page">
  <main>
    @Body
  </main>
</div>

@code {
  private bool esOscuro = true;

  protected override async Task OnInitializedAsync()
  {
    var actual = await JS.InvokeAsync<string>("themeInterop.get");
    esOscuro = actual != "light";
  }

  private async Task ToggleTheme()
  {
    esOscuro = !esOscuro;
    await JS.InvokeVoidAsync("themeInterop.set", esOscuro ? "dark" : "light");
  }

  private async Task CerrarSesion()
  {
    await Auth.CerrarSesionAsync();
    Nav.NavigateTo("/login", forceLoad: true);
  }
}