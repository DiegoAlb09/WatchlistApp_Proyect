@page "/libros"
@inject LibraryStorageService Storage
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="libros-theme">
    <div class="header">
        <h1><Icon Name="book" />Libros, Manga y Cómics</h1>
        <button class="btn-add" @onclick="IrAAgregar">+ Agregar</button>
    </div>

    @if (items is null)
    {
        <p>Cargando...</p>
    }
    else
    {
        <div class="filters">
            <button class="@(filtro == null ? "filtro-activo" : "")" @onclick="() => filtro = null">Todo</button>
            <button class="@(filtro == TipoLibro.Libro ? "filtro-activo" : "")" @onclick="() => filtro = TipoLibro.Libro">Libros</button>
            <button class="@(filtro == TipoLibro.Manga ? "filtro-activo" : "")" @onclick="() => filtro = TipoLibro.Manga">Manga</button>
            <button class="@(filtro == TipoLibro.Comic ? "filtro-activo" : "")" @onclick="() => filtro = TipoLibro.Comic">Cómics</button>
        </div>

        @if (!ItemsFiltrados.Any())
        {
            <p class="empty-msg">Aún no has agregado nada.</p>
        }
        else
        {
            <div class="libro-lista">
                @foreach (var libro in ItemsFiltrados)
                {
                    <div class="libro-row">
                        <div class="libro-cover" style="background-image:url('@libro.PortadaUrl')">
                            @if (string.IsNullOrWhiteSpace(libro.PortadaUrl))
                            {
                                <span class="no-cover"><Icon Name="photo" /></span>
                            }
                        </div>
                        <div class="libro-info">
                            <h3>@libro.Titulo</h3>
                            <p class="tipo-tag">@libro.Tipo</p>

                            <div class="stepper">
                                <button @onclick="() => CambiarCapitulo(libro, -1)"><Icon Name="minus" /></button>
                                <span>
                                    Cap. @libro.CapituloActual
                                    @(libro.CapituloFin is not null ? $" / {libro.CapituloFin}" : "")
                                </span>
                                <button @onclick="() => CambiarCapitulo(libro, 1)"><Icon Name="plus" /></button>
                            </div>

                            @if (libro.Porcentaje is not null)
                            {
                                <div class="mini-progress">
                                    <div class="mini-progress-fill" style="width:@(libro.Porcentaje)%"></div>
                                </div>
                            }
                        </div>
                        <div class="libro-actions">
                            <button class="btn-edit" @onclick="() => Editar(libro.Id)"><Icon Name="pencil" />Editar</button>
                            <button class="btn-delete" @onclick="() => Eliminar(libro.Id, libro.Titulo)"><Icon Name="trash" />Eliminar</button>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private List<LibroItem>? items;
    private TipoLibro? filtro;

    private IEnumerable<LibroItem> ItemsFiltrados =>
        items is null ? Enumerable.Empty<LibroItem>()
        : filtro is null ? items
        : items.Where(i => i.Tipo == filtro);

    protected override async Task OnInitializedAsync()
    {
        items = await Storage.GetAllAsync();
    }

    private void IrAAgregar() => Nav.NavigateTo("/libros/agregar");

    private void Editar(Guid id) => Nav.NavigateTo($"/libros/agregar/{id}");

    private async Task CambiarCapitulo(LibroItem libro, int delta)
    {
        var nuevo = libro.CapituloActual + delta;
        if (nuevo < libro.CapituloInicio) nuevo = libro.CapituloInicio;
        if (libro.CapituloFin is not null && nuevo > libro.CapituloFin) nuevo = libro.CapituloFin.Value;

        libro.CapituloActual = nuevo;
        await Storage.UpdateAsync(libro);
    }

    private async Task Eliminar(Guid id, string titulo)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", $"¿Eliminar \"{titulo}\" de tu lista?");
        if (!confirmado) return;

        await Storage.DeleteAsync(id);
        items = await Storage.GetAllAsync();
    }
}